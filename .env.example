# ========================
# Core Application
# ========================
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret

# ========================
# Database (Neon PostgreSQL)
# ========================
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/callrevive
DATABASE_SYNC_URL=postgresql://user:password@host:5432/callrevive
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ========================
# Redis (Upstash)
# ========================
REDIS_URL=redis://default:password@host:6379

# ========================
# Message Queue (CloudAMQP)
# ========================
CLOUDAMQP_URL=amqp://user:password@host:5672/vhost

# ========================
# AI (Google Gemini)
# ========================
GEMINI_API_KEY=your-gemini-api-key

# ========================
# Twilio
# ========================
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ========================
# Storage (Backblaze B2)
# ========================
BACKBLAZE_KEY_ID=your-key-id
BACKBLAZE_APPLICATION_KEY=your-app-key
BACKBLAZE_BUCKET_NAME=callrevive-recordings
BACKBLAZE_BUCKET_ID=your-bucket-id
BACKBLAZE_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com

# ========================
# Auth (JWT)
# ========================
JWT_SECRET=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================
# URLs
# ========================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ========================
# Monitoring
# ========================
PROMETHEUS_ENABLED=true
